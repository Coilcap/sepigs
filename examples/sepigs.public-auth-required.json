{
  "configVersion": 1,
  "log": {
    "level": "warn"
  },
  "observability": {
    "metrics": {
      "enabled": true,
      "listen": "127.0.0.1",
      "port": 19090,
      "path": "/metrics"
    }
  },
  "plugins": {
    "modules": [],
    "wasm": [],
    "isolation": {
      "mode": "worker-thread",
      "timeoutMs": 3000,
      "memoryLimitMb": 64,
      "stdoutLimitBytes": 65536
    }
  },
  "inbounds": [
    {
      "type": "http",
      "tag": "http-public",
      "listen": "0.0.0.0",
      "port": 8080,
      "auth": {
        "enabled": true,
        "username": "change-me",
        "password": "change-me-long-random-password"
      }
    },
    {
      "type": "socks5",
      "tag": "socks-public",
      "listen": "0.0.0.0",
      "port": 1080,
      "udpAssociate": false,
      "auth": {
        "enabled": true,
        "username": "change-me",
        "password": "change-me-long-random-password"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "defaultOutbound": "direct",
    "rules": []
  }
}
